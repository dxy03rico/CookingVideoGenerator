# FFmpeg path (Homebrew on macOS)
FFMPEG_PATH=/opt/homebrew/bin/ffmpeg
FFPROBE_PATH=/opt/homebrew/bin/ffprobe

# --- 当前使用：fal.ai (Kling v1.6) ---
# 注册：https://fal.ai/dashboard/keys
FAL_KEY=your_fal_key_here

# --- 备用：Kling AI 直连（积分与网页端分开，需单独充值）---
# KLING_ACCESS_KEY=your_kling_access_key
# KLING_SECRET_KEY=your_kling_secret_key

# --- 待启用：Seedance 2.0（API 开放后使用）---
# SEEDANCE_API_KEY=your_seedance_key
# SEEDANCE_API_BASE=https://api.seedance.ai
